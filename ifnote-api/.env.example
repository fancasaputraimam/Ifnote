# --- DATABASE ---
# Heroku Postgres connection string. Local dev contoh:
#   postgresql://USER:PASSWORD@localhost:5432/ifnote?schema=public
# Heroku otomatis set DATABASE_URL saat addon postgres dipasang.
DATABASE_URL="postgresql://user:password@localhost:5432/ifnote?schema=public"

# --- AUTH (server-side only, JANGAN expose ke frontend) ---
JWT_SECRET="ganti-dengan-string-acak-panjang-min-32-karakter"
JWT_EXPIRES_IN="7d"

# --- AI PROXY (server-side only) ---
AI_API_KEY=""
AI_BASE_URL="https://api.openai.com/v1"
AI_MODEL_ID="gpt-4o-mini"
AI_REQUEST_FORMAT="openai"

# --- CORS ---
FRONTEND_URL="http://localhost:3000"

# --- ENV ---
NODE_ENV="development"

# --- SEED (opsional) ---
# Email user yang sudah ada di DB untuk di-seed konten default Jepang.
# Kosongkan kalau tidak mau pakai seed otomatis.
SEED_USER_EMAIL=""
